# OpenSiteBackup self-contained config
# Copy to: config/env.sh

export OSB_HOME="/home/kingb/.openclaw/workspace/opensitebackup"

# Derived default paths (self-contained)
export OSB_CONFIG="${OSB_HOME}/config/env.sh"
export OSB_BACKUPS="${OSB_HOME}/data/backups"
export OSB_LOGS="${OSB_HOME}/data/logs"
export OSB_TMP="${OSB_HOME}/data/tmp"
export OSB_STATE="${OSB_HOME}/data/state"

# Source host (example: WordPress over SSH)
export LIVE_SSH_HOST="50.87.170.84"
export LIVE_SSH_USER="tbsoftwa"
export LIVE_SITE_PATH="/home/tbsoftwa/public_html"
export LIVE_SSH_KEY="$HOME/.ssh/id_ed25519"

# Optional: restore target outside OSB_HOME
export LOCAL_RESTORE_PATH="/home/kingb/sites/tbsoftwash.com"
export LOCAL_URL="http://localhost:8080"

# Upload backend selection
# local | rclone | gog
export OSB_BACKEND="local"

# Optional backend-specific variables
# export DRIVE_ACCOUNT="you@gmail.com"
# export DRIVE_FILES_FOLDER_ID="..."
# export DRIVE_DB_FOLDER_ID="..."
