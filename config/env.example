# OpenSiteBackup self-contained config
# Copy to: config/env.sh

export OSB_HOME="/home/kingb/.openclaw/workspace/opensitebackup"
export OSB_CONFIG="${OSB_HOME}/config/env.sh"

# Source/site identity
export SOURCE_KIND="wordpress"
export SOURCE_SITE_SLUG="site"

# Self-contained paths
export OSB_BACKUPS="${OSB_HOME}/data/backups/${SOURCE_SITE_SLUG}-live"
export OSB_LOGS="${OSB_HOME}/data/logs"
export OSB_TMP="${OSB_HOME}/data/tmp"
export OSB_STATE="${OSB_HOME}/data/state"

# Source host (WordPress over SSH)
export LIVE_SSH_HOST="example.com"
export LIVE_SSH_USER="wpuser"
export LIVE_SSH_PORT="22"
export LIVE_SITE_PATH="/home/wpuser/public_html"
export LIVE_SSH_KEY="$HOME/.ssh/id_ed25519"

# Restore target + local DB settings
export LOCAL_RESTORE_PATH="${OSB_HOME}/data/sites/${SOURCE_SITE_SLUG}"
export LOCAL_URL="http://localhost:8080"
export LOCAL_DB_NAME="wp_local"
export LOCAL_DB_USER="wp_user"
export LOCAL_DB_PASSWORD="change-me"
export LOCAL_DB_HOST="localhost"
export LOCAL_DB_PORT="3306"

# Dynamic URL rewrite mapping pairs
export OSB_REWRITE_FROM_1="https://example.com"
export OSB_REWRITE_TO_1="${LOCAL_URL}"
# export OSB_REWRITE_FROM_2="http://example.com"
# export OSB_REWRITE_TO_2="${LOCAL_URL}"

# Upload backend selection: local | rclone | gog(optional)
export OSB_BACKEND="local"

# local backend
export LOCAL_UPLOAD_ROOT="${OSB_STATE}/local_uploads"

# rclone backend
# export RCLONE_REMOTE="myremote:Backups/WordPress/<site-slug>"
# export RCLONE_FLAGS="--progress"

# gog backend (optional)
# export DRIVE_ACCOUNT="you@example.com"
# export DRIVE_FILES_FOLDER_ID="..."
# export DRIVE_DB_FOLDER_ID="..."
# export DRIVE_MANIFESTS_FOLDER_ID="..."
# export DRIVE_DB_FILE_ID="..."
# export DRIVE_FILES_FILE_ID="..."

# Reliability controls
export OSB_UPLOAD_RETRIES="2"
export OSB_UPLOAD_RETRY_DELAY_SEC="3"
export OSB_LOCK_TIMEOUT_SEC="600"
# auto-clear stale locks when detected (1=yes, 0=ask)
export OSB_LOCK_CLEAR_STALE="0"
export OSB_RESTORE_CONFIRM_REQUIRED="1"
# enforce restore drill during release-candidate checks
export OSB_RC_MODE="0"
export OSB_LOG_JSON="0"
# Optional fixed run id override (normally auto-generated)
# export OSB_RUN_ID="<uuid-or-custom-run-id>"

# Retention policy
export OSB_RETENTION_DAILY="7"
export OSB_RETENTION_WEEKLY="8"
export OSB_RETENTION_MONTHLY="12"
export OSB_RETENTION_PRUNE_EMPTY="1"
